{
  "info": {
    "name": "QSI - Contributions API (US2 & US3)",
    "_postman_id": "4e5ad9b7-e4c0-4af9-8df9-86e3a9e13de9",
    "description": "Collection pour tester les endpoints de l'US2 (consultation des contributions) et US3 (refund campagne).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "US2 - Consulter les contributions",
      "item": [
        {
          "name": "GET /user/:userId/contributions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}/contributions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}",
                "contributions"
              ]
            },
            "description": "Retourne la liste des contributions de l'utilisateur."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /user/:userId/contributions/:contributionId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}/contributions/{{contributionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}",
                "contributions",
                "{{contributionId}}"
              ]
            },
            "description": "Retourne le détail d'une contribution de l'utilisateur."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "US3 - Refund campagne échouée",
      "item": [
        {
          "name": "POST /campaigns/:campaignId/refund",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/campaigns/{{campaignId}}/refund",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "campaigns",
                "{{campaignId}}",
                "refund"
              ]
            },
            "description": "Déclenche le changement d'état des contributions de la campagne en refunded."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains refunded status', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.status).to.eql('refunded');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "contributionId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "campaignId",
      "value": "1",
      "type": "string"
    }
  ]
}
